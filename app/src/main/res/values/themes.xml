        <item name="colorPrimary">@color/primary_deep</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_emerald</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        
        <!-- UI Elements -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_high_emphasis</item>
    </style>

    <style name="Theme.PayBhama" parent="Base.Theme.PayBhama" />
</resources>

